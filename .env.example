# Vaultfire Enterprise — Environment Variables Example
# NEVER put real values here. Use actual environment variables in production.

# RPC Endpoints (optional — defaults provided)
VAULTFIRE_BASE_RPC=https://mainnet.base.org
VAULTFIRE_AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
VAULTFIRE_ARBITRUM_RPC=https://arbitrum-one.publicnode.com
VAULTFIRE_POLYGON_RPC=https://polygon-bor-rpc.publicnode.com

# IAM Provider Configuration
OKTA_DOMAIN=your-org.okta.com
OKTA_API_TOKEN=your-okta-api-token-here

AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

OIDC_ISSUER=https://your-oidc-issuer.com
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret

# Signing key for middleware JWT verification (if used)
# NEVER store actual private keys — use a secrets manager
VAULTFIRE_MIDDLEWARE_SECRET=your-middleware-jwt-secret
