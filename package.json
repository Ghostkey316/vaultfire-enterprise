{
  "name": "@vaultfire/enterprise",
  "version": "1.0.0",
  "description": "Bridge enterprise IAM systems (Okta, Azure AD, OIDC) with Vaultfire on-chain agent identity and trust infrastructure",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --forceExit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "vaultfire",
    "enterprise",
    "iam",
    "okta",
    "azure-ad",
    "oidc",
    "agent-identity",
    "trust",
    "blockchain",
    "web3",
    "ai-agents"
  ],
  "author": "Ghostkey316 <ghostkey316@proton.me>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghostkey316/vaultfire-enterprise"
  },
  "homepage": "https://theloopbreaker.com",
  "dependencies": {
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
